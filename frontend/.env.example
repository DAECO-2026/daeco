# 백엔드 오리진 (Spring Boot). 로컬 기본값 http://localhost:8080
BACKEND_ORIGIN=http://localhost:8080

# 카카오 REST API 키 (역지오코딩·장소검색·길찾기용). 서버 전용
# https://developers.kakao.com 앱 생성 후 REST API 키 입력
KAKAO_REST_API_KEY=

# 카카오 지도 JavaScript 키 (지도 렌더링용). 클라이언트에 노출됨(도메인 등록으로 보호)
# 카카오 콘솔 > 플랫폼 > Web 에 도메인(http://localhost:3000) 등록 필요
NEXT_PUBLIC_KAKAO_JS_KEY=
